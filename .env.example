NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
OPENAI_API_KEY=

NEXT_PUBLIC_APP_URL=http://localhost:3000

# Acquisition E-Mail-Cron (Vercel Cron → GET /api/acquisition/process)
ACQUISITION_CRON_SECRET=
# Vercel setzt CRON_SECRET automatisch im Authorization-Header bei Cron-Jobs
CRON_SECRET=
# Täglicher Jarvis Lead Research (GET /api/jarvis/lead-research/run) — optional, sonst CRON_SECRET
# LEAD_RESEARCH_CRON_SECRET=

# Jarvis Lead Research — automatische Quellen (RSS/Scraper, Stand Juli 2026)
# evergabe.de + Vergabe24: service.bund.de Keyword-/Kategorie-RSS (kein eigenes Tender-RSS)
# DTAD: TED Search API (kein öffentliches DTAD-RSS)
# Subreport: HTML-Einbettung ITK Rheinland
# Optional zusätzliche Feeds:
# JARVIS_SCRAPER_EVERGABE_RSS=
# JARVIS_SCRAPER_VERGABE24_RSS=
# JARVIS_SCRAPER_DTAD_RSS=
# JARVIS_SCRAPER_SUBREPORT_RSS=

# Jarvis Sales/Traffic — nur für Admin-E-Mails (kommagetrennt)
JARVIS_ADMIN_EMAILS=nico.thomas@tknd-unity-gbr.de

# Stripe Billing
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

STRIPE_PRICE_STARTER=
STRIPE_PRICE_BUSINESS=
STRIPE_PRICE_CONSULTANT=
STRIPE_PRICE_PILOT_MONTHLY=
STRIPE_PRICE_PILOT_SETUP=
# Dauer der einmaligen Pilotphase in Tagen (danach Abo wählen). Standard: 30
STRIPE_PILOT_TRIAL_DAYS=30

# Stripe Payment Links (optional, z. B. Basis/Starter ohne Checkout-API)
NEXT_PUBLIC_STRIPE_PAYMENT_LINK_STARTER=https://buy.stripe.com/aFaeVf8bP0fu5j12ws8EM03
NEXT_PUBLIC_STRIPE_PAYMENT_LINK_BUSINESS=https://buy.stripe.com/9B64gB4ZD9Q4eTBefa8EM04
NEXT_PUBLIC_STRIPE_PAYMENT_LINK_CONSULTANT=https://buy.stripe.com/cNi5kF8bP9Q4eTB6MI8EM05

# Stripe Kundenportal (Login-Link für Abo-Verwaltung)
NEXT_PUBLIC_STRIPE_PORTAL_LOGIN_URL=https://billing.stripe.com/p/login/8x25kF77Ld2gfXF8UQ8EM00

# Pilotanfragen — Benachrichtigung an nico.thomas@tknd-unity-gbr.de
PILOT_NOTIFICATION_EMAIL=nico.thomas@tknd-unity-gbr.de

# Option A: Resend (https://resend.com)
RESEND_API_KEY=
PILOT_EMAIL_FROM=TKND NIS2 <notifications@tknd-unity-gbr.de>

# Option B: Strato SMTP (wie eigenes CRM) — https://www.strato.de/faq/mail/e-mailserver-adressen-ports-ssl-tls/
# SMTP_HOST=smtp.strato.de
# SMTP_PORT=465
# SMTP_SECURE=true
# SMTP_USER=info@tknd-unity-gbr.com
# SMTP_PASS=Strato-Postfach-Passwort für SMTP_USER
# PILOT_EMAIL_FROM=info@tknd-unity-gbr.com

# Option C: Microsoft Graph API (wie viele CRMs — kein SMTP-Login nötig)
# Azure App-Registrierung mit Anwendungsberechtigung „Mail.Send“ + Admin-Einwilligung
# AZURE_TENANT_ID=
# AZURE_CLIENT_ID=
# AZURE_CLIENT_SECRET=
# MS_GRAPH_SEND_AS=nico.thomas@tknd-unity-gbr.de

# LinkedIn Publishing (Jarvis — manuelles Veröffentlichen per Klick)
# LinkedIn Developer App: https://www.linkedin.com/developers/
# Redirect-URI: {NEXT_PUBLIC_APP_URL}/api/jarvis/linkedin-publishing/oauth/callback
# LINKEDIN_CLIENT_ID=
# LINKEDIN_CLIENT_SECRET=
